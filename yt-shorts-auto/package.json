{
  "name": "yt-shorts-auto",
  "version": "1.0.0",
  "description": "Automated faceless YouTube Shorts channel — fun word of the day",
  "type": "module",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc",
    "produce": "tsx src/cli.ts produce",
    "produce:dry": "tsx src/cli.ts produce --dry-run",
    "produce:no-upload": "tsx src/cli.ts produce --no-upload",
    "produce:reddit": "tsx src/cli.ts produce --source=reddit",
    "produce:fallback": "tsx src/cli.ts produce --source=fallback",
    "produce:word": "tsx src/cli.ts produce --word=susurrus",
    "produce:batch": "tsx src/cli.ts produce --batch 3",
    "produce:rss": "tsx src/cli.ts produce --source=rss",
    "scout": "tsx scripts/trend-scout.ts",
    "scout:dry": "tsx scripts/trend-scout.ts --dry-run",
    "scout:yt": "tsx scripts/trend-scout.ts --yt-only",
    "scout:rss": "tsx scripts/trend-scout.ts --rss-only",
    "scout:competitors": "tsx scripts/trend-scout.ts --competitors-only",
    "scout:review": "tsx scripts/review-ideas.ts",
    "scout:review:no-claude": "tsx scripts/review-ideas.ts --no-claude",
    "setup:oauth": "tsx scripts/setup-oauth.ts",
    "setup:music": "tsx scripts/seed-music.ts",
    "remotion:preview": "remotion preview src/remotion/index.ts",
    "remotion:render": "remotion render src/remotion/index.ts ShortVideo --output output/test.mp4",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts,.tsx",
    "db:reset": "node -e \"try{require('fs').unlinkSync('db/words.db')}catch(e){}\" && tsx -e \"import './src/utils/db'; console.log('DB reset')\"",
    "postinstall": "node -e \"['output','db','assets/music','assets/fonts'].forEach(d=>require('fs').mkdirSync(d,{recursive:true}))\""
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/captions": "^4.0.428",
    "@remotion/cli": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "bad-words": "^3.0.4",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "culori": "^4.0.2",
    "dotenv": "^16.4.0",
    "googleapis": "^140.0.0",
    "node-fetch": "^3.3.0",
    "open": "^10.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "remotion": "^4.0.0",
    "remotion-bits": "^0.1.14",
    "snoowrap": "^1.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@remotion/eslint-config": "^4.0.0",
    "@types/bad-words": "^3.0.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
