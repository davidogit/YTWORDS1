# ── Reddit API (create app at https://www.reddit.com/prefs/apps) ──
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=yt-shorts-auto:v1.0.0 (by /u/your_username)

# ── Dictionary API (dictionaryapi.dev is free, no key needed) ──
# Optional: Wordnik API key for supplementary lookups
WORDNIK_API_KEY=optional_wordnik_key

# ── OpenAI (optional — for LLM-generated hooks & definitions) ──
OPENAI_API_KEY=sk-optional-for-llm-hooks

# ── Anthropic / Claude (optional — for scout:review script generation) ──
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-optional-for-idea-scripts

# ── TTS Engine ──
# Options: "edge-tts" (free, default), "coqui", "openai"
TTS_ENGINE=edge-tts
# edge-tts voice (run `edge-tts --list-voices` for options)
TTS_VOICE=en-US-GuyNeural
# OpenAI TTS voice (if using openai engine): alloy, echo, fable, onyx, nova, shimmer
OPENAI_TTS_VOICE=onyx

# ── YouTube Data API v3 ──
# Create OAuth2 credentials at https://console.cloud.google.com
YT_CLIENT_ID=your_google_oauth_client_id
YT_CLIENT_SECRET=your_google_oauth_client_secret
YT_REDIRECT_URI=http://localhost:3000/oauth2callback
# This is populated by scripts/setup-oauth.ts after first auth
YT_REFRESH_TOKEN=

# ── YouTube API Key (for Trend Scout read operations) ──
# The OAuth token above only covers uploads. The scout needs read access.
# GCP Console → APIs & Services → Credentials → + Create Credentials → API Key
# Restrict the key to "YouTube Data API v3" for safety.
YT_API_KEY=your_youtube_api_key

# ── FFmpeg ──
FFMPEG_PATH=ffmpeg

# ── Paths ──
OUTPUT_DIR=./output
MUSIC_DIR=./assets/music
DB_PATH=./db/words.db

# ── Content Settings ──
TARGET_SUBREDDITS=logophilia,wordoftheday,vocabulary,todayilearned,etymology
MIN_WORD_LENGTH=5
MAX_WORD_LENGTH=20
MIN_QUALITY_SCORE=0.5

# ── YouTube Upload Defaults ──
YT_CHANNEL_CATEGORY=27
YT_DEFAULT_TAGS=shorts,vocabulary,words,english,funwords,wordoftheday,learnEnglish
YT_PRIVACY=public
